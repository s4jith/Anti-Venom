# Anti-Venom environment variables
# Copy this file to .env and fill in values — .env is gitignored

# HuggingFace token (optional — for higher rate limits when downloading datasets)
# HF_TOKEN=hf_...

# Redis cache backend (optional — for v0.2 distributed cache)
# REDIS_URL=redis://localhost:6379/0

# Webhook proxy upstream (used by `antivenom serve`)
# ANTIVENOM_UPSTREAM_URL=https://api.openai.com/v1/embeddings
# ANTIVENOM_UPSTREAM_AUTH=Bearer sk-...

# Audit database path override
# ANTIVENOM_DB_PATH=antivenom_audit.db

# Audit log path override
# ANTIVENOM_LOG_PATH=antivenom_audit.jsonl

# Ollama endpoint (for v0.3 LLM Judge layer)
# OLLAMA_BASE_URL=http://localhost:11434
